<!DOCTYPE html>
<html>
<head>
    <title>TOXIC BATTLE</title>
    <style>
        :root { --main: #2ecc71; --dark: #0b0e0f; --panel: #141a1c; --gold: #caab05; }
        body { background: var(--dark); color: white; font-family: 'Arial', sans-serif; margin: 0; overflow-x: hidden; }
        
        /* Live Feed */
        .feed { display: flex; height: 65px; background: #0a0c0d; gap: 5px; padding: 5px; border-bottom: 1px solid #1f2526; justify-content: center; }
        .f-item { width: 55px; height: 55px; background: var(--panel); border-bottom: 2px solid var(--main); position: relative; transition: 0.3s; }
        .f-item img { width: 100%; }

        header { padding: 15px 50px; display: flex; justify-content: space-between; align-items: center; background: var(--panel); border-bottom: 1px solid #222; }
        .logo { font-size: 26px; font-weight: 900; color: var(--main); }

        /* Roulette */
        .roulette { width: 100%; height: 160px; background: #0e1213; position: relative; margin: 30px 0; overflow: hidden; border-y: 1px solid #1f2526; }
        .tape { display: flex; transition: transform 5s cubic-bezier(0.1, 0, 0.1, 1); }
        .r-item { min-width: 150px; height: 150px; background: var(--panel); margin: 5px; display: flex; align-items: center; justify-content: center; border-bottom: 4px solid #333; }
        .r-item img { width: 100px; }
        .pointer { position: absolute; left: 50%; width: 2px; height: 100%; background: var(--main); z-index: 5; box-shadow: 0 0 15px var(--main); }

        .btn { background: var(--main); color: #000; border: none; padding: 15px 50px; font-weight: 900; border-radius: 4px; cursor: pointer; transition: 0.3s; }
        .btn:hover { box-shadow: 0 0 20px var(--main); transform: translateY(-2px); }

        .inventory { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 15px; padding: 50px; }
        .inv-card { background: var(--panel); padding: 15px; border-radius: 8px; border: 1px solid #222; text-align: center; }
        .rarity-gold { border-color: var(--gold) !important; }
    </style>
</head>
<body>
    <div class="feed" id="liveFeed">
        <% drops.forEach(d => { %><div class="f-item"><img src="<%= d.img %>"></div><% }) %>
    </div>
    
    <header>
        <div class="logo">TOXIC<span>BATTLE</span></div>
        <% if (user) { %>
            <div><%= user.name %> | <b id="bal" style="color:var(--main)"><%= user.balance %></b>₽</div>
        <% } else { %>
            <a href="/auth/steam" class="btn" style="padding: 10px 20px;">ВОЙТИ</a>
        <% } %>
    </header>

    <div class="roulette">
        <div class="pointer"></div>
        <div id="tape" class="tape"></div>
    </div>

    <center><button class="btn" id="openBtn" onclick="openCase()">ОТКРЫТЬ КЕЙС (100₽)</button></center>

    <div class="inventory" id="inv">
        <% if (user) { user.inventory.reverse().forEach(i => { %>
            <div class="inv-card rarity-<%=i.rarity%>"><img src="<%=i.img%>" width="80"><p style="font-size:10px"><%=i.name%></p></div>
        <% })} %>
    </div>

    <script>
        const tape = document.getElementById('tape');
        const items = <%- JSON.stringify(items) %>;
        
        function initTape() {
            tape.innerHTML = '';
            for(let i=0; i<100; i++) {
                const it = items[Math.floor(Math.random()*items.length)];
                tape.innerHTML += `<div class="r-item rarity-${it.rarity}"><img src="${it.img}"></div>`;
            }
        }
        initTape();

        async function openCase() {
            const res = await fetch('/open', {method:'POST'});
            const data = await res.json();
            if(data.error) return alert(data.error);

            document.getElementById('bal').innerText = data.balance;
            const winIdx = 80;
            tape.children[winIdx].innerHTML = `<img src="${data.win.img}">`;
            tape.children[winIdx].className = `r-item rarity-${data.win.rarity}`;
            
            const offset = (winIdx * 160) - (window.innerWidth / 2) + 80;
            tape.style.transform = `translateX(-${offset}px)`;
            setTimeout(() => location.reload(), 6000);
        }
    </script>
</body>
</html>
