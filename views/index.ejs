<!DOCTYPE html>
<html>
<head>
    <title>TOXIC BATTLE</title>
    <style>
        :root { --main: #2ecc71; --dark: #0b0e0f; --panel: #141a1c; --gold: #caab05; }
        body { background: var(--dark); color: white; font-family: sans-serif; margin: 0; overflow-x: hidden; }
        header { background: var(--panel); padding: 15px 50px; display: flex; justify-content: space-between; border-bottom: 2px solid var(--main); }
        .feed { display: flex; height: 60px; background: #000; overflow: hidden; gap: 5px; padding: 5px; border-bottom: 1px solid #222; }
        .f-item { min-width: 50px; background: var(--panel); border-bottom: 2px solid var(--main); box-shadow: 0 0 5px var(--main); }
        .roulette { width: 100%; height: 160px; background: #0e1213; overflow: hidden; position: relative; margin: 20px 0; }
        .tape { display: flex; transition: transform 5s cubic-bezier(0.1, 0, 0.1, 1); }
        .item { min-width: 150px; height: 150px; display: flex; align-items: center; justify-content: center; background: var(--panel); margin: 0 5px; border-bottom: 4px solid #333; }
        .pointer { position: absolute; left: 50%; width: 2px; height: 100%; background: var(--main); z-index: 5; box-shadow: 0 0 15px var(--main); }
        .btn { background: var(--main); border: none; padding: 15px 40px; font-weight: bold; cursor: pointer; border-radius: 4px; color: #000; }
        .cases-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 20px; padding: 40px; }
        .case-card { background: var(--panel); padding: 20px; text-align: center; border-radius: 10px; cursor: pointer; border: 1px solid #222; transition: 0.3s; }
        .case-card:hover { border-color: var(--main); transform: translateY(-5px); }
        .rarity-gold { border-color: var(--gold) !important; }
        .xp-bar { width: 100%; height: 5px; background: #222; margin-top: 10px; }
        .xp-fill { height: 100%; background: var(--main); box-shadow: 0 0 10px var(--main); }
    </style>
</head>
<body>
    <div class="feed" id="liveFeed"><% drops.forEach(d => { %><div class="f-item"><img src="<%= d.img %>" width="100%"></div><% }) %></div>
    <header>
        <div style="font-size:24px; font-weight:900; color:var(--main)">TOXIC BATTLE</div>
        <% if (user) { %>
            <div style="text-align:right">
                <b><%= user.name %></b> | <span id="bal"><%= user.balance %></span>₽<br>
                <div class="xp-bar"><div class="xp-fill" id="xpF" style="width:<%= user.xp/10 %>%"></div></div>
            </div>
        <% } else { %>
            <a href="/auth/steam"><button class="btn">ВОЙТИ</button></a>
        <% } %>
    </header>

    <div class="roulette"><div class="pointer"></div><div id="tape" class="tape"></div></div>
    <center><button class="btn" id="openBtn" onclick="openCase()" disabled>ВЫБЕРИТЕ КЕЙС</button></center>

    <div class="cases-grid">
        <% for(let k in cases) { %>
            <div class="case-card" onclick="selCase('<%=k%>', <%=cases[k].price%>)">
                <img src="<%=cases[k].img%>" width="120"><br><b><%=cases[k].name%></b><br><span style="color:var(--main)"><%=cases[k].price%>₽</span>
            </div>
        <% } %>
    </div>

    <div id="inv-grid" style="display:flex; flex-wrap:wrap; padding:40px; gap:10px"></div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        let curCase = '', allCases = <%- JSON.stringify(cases) %>;
        const tape = document.getElementById('tape'), tick = new Audio('https://raw.githubusercontent.com');

        function selCase(id, price) {
            curCase = id;
            document.getElementById('openBtn').disabled = false;
            document.getElementById('openBtn').innerText = 'ОТКРЫТЬ ЗА ' + price + '₽';
            tape.innerHTML = '';
            for(let i=0; i<100; i++) {
                let it = allCases[id].items[Math.floor(Math.random()*allCases[id].items.length)];
                tape.innerHTML += `<div class="item"><img src="${it.img}" width="100"></div>`;
            }
            window.scrollTo({top:0, behavior:'smooth'});
        }

        async function openCase() {
            const res = await fetch('/open/'+curCase, {method:'POST'});
            const data = await res.json();
            if(data.error) return alert(data.error);

            document.getElementById('bal').innerText = data.balance;
            tape.children[80].innerHTML = `<img src="${data.win.img}" width="100">`;
            tape.children[80].className = `item rarity-${data.win.rarity}`;
            tape.style.transform = `translateX(-${(80*160) - (window.innerWidth/2) + 80}px)`;

            let lastI = 0;
            const loop = () => {
                let curI = Math.floor(Math.abs(new WebKitCSSMatrix(getComputedStyle(tape).transform).m41) / 160);
                if(curI !== lastI) { tick.currentTime=0; tick.play(); lastI=curI; }
                if(lastI < 80) requestAnimationFrame(loop);
            };
            requestAnimationFrame(loop);
            setTimeout(() => location.reload(), 6000);
        }

        socket.on('newDrop', d => {
            const f = document.getElementById('liveFeed');
            f.innerHTML = `<div class="f-item"><img src="${d.img}" width="100%"></div>` + f.innerHTML;
        });
    </script>
</body>
</html>
