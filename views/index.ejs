<!DOCTYPE html>
<html>
<head>
    <title>TOXIC BATTLE</title>
    <style>
        :root { --main: #2ecc71; --dark: #0b0e0f; --card: #141a1c; }
        body { background: var(--dark); color: white; font-family: sans-serif; margin: 0; overflow-x: hidden; }
        .live-feed { display: flex; height: 60px; background: #0e1213; border-bottom: 2px solid var(--main); gap: 10px; padding: 5px; justify-content: center; }
        .feed-item { width: 50px; border-radius: 4px; border-bottom: 2px solid var(--main); background: var(--card); }
        header { background: var(--card); padding: 15px 50px; display: flex; justify-content: space-between; align-items: center; }
        .roulette { width: 100%; height: 160px; background: #0e1213; overflow: hidden; position: relative; margin: 30px 0; }
        .tape { display: flex; transition: transform 5s cubic-bezier(0.1, 0, 0.1, 1); }
        .item { min-width: 150px; height: 150px; background: var(--card); margin: 5px; display: flex; align-items: center; justify-content: center; border-bottom: 4px solid #333; }
        .pointer { position: absolute; left: 50%; width: 2px; height: 100%; background: var(--main); z-index: 5; box-shadow: 0 0 15px var(--main); }
        .btn { background: var(--main); border: none; padding: 15px 40px; font-weight: bold; cursor: pointer; border-radius: 5px; font-size: 18px; }
        .inventory { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 15px; padding: 40px; }
    </style>
</head>
<body>
    <div class="live-feed">
        <% drops.forEach(d => { %><div class="feed-item"><img src="<%= d.img %>" width="100%"></div><% }) %>
    </div>
    <header>
        <div style="font-size:24px; font-weight:900; color:var(--main)">TOXIC<span>BATTLE</span></div>
        <% if (user) { %>
            <div><%= user.name %> | <b id="bal"><%= user.balance %></b>₽</div>
        <% } else { %>
            <a href="/auth/steam"><button class="btn">ВОЙТИ</button></a>
        <% } %>
    </header>

    <div class="roulette">
        <div class="pointer"></div>
        <div id="tape" class="tape"></div>
    </div>

    <center><button class="btn" onclick="spin()">ОТКРЫТЬ КЕЙС (100₽)</button></center>

    <div class="inventory">
        <% if (user) { user.inventory.reverse().forEach(i => { %>
            <div class="item" style="height: 120px;"><img src="<%= i.img %>" width="80"></div>
        <% })} %>
    </div>

    <script>
        const tape = document.getElementById('tape');
        const items = <%- JSON.stringify(items) %>;
        for(let i=0; i<100; i++) {
            const it = items[Math.floor(Math.random()*items.length)];
            tape.innerHTML += `<div class="item"><img src="${it.img}" width="100"></div>`;
        }

        async function spin() {
            const res = await fetch('/open', {method:'POST'});
            const data = await res.json();
            if(data.error) return alert(data.error);
            document.getElementById('bal').innerText = data.balance;
            const winIdx = 80;
            tape.children[winIdx].innerHTML = `<img src="${data.win.img}" width="100">`;
            const offset = (winIdx * 160) - (window.innerWidth / 2) + 80;
            tape.style.transform = `translateX(-${offset}px)`;
            setTimeout(() => location.reload(), 6000);
        }
    </script>
</body>
</html>

